rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    function memberDoc(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    function isTeamMember(teamId) {
      return isSignedIn() && memberDoc(teamId).data != null;
    }

    function memberRole(teamId) {
      return memberDoc(teamId).data.role;
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && memberRole(teamId) == 'admin';
    }

    function isTeamManager(teamId) {
      return isSignedIn() && memberRole(teamId) == 'manager';
    }

    function isTeamAuditor(teamId) {
      return isSignedIn() && memberRole(teamId) == 'auditor';
    }

    function isTeamAdminOrManager(teamId) {
      return isTeamAdmin(teamId) || isTeamManager(teamId);
    }

    function isTeamLeadershipOrAuditor(teamId) {
      return isTeamAdminOrManager(teamId) || isTeamAuditor(teamId);
    }

    function timesheetOptionalFields(r) {
      return (!('activity' in r) || (r.activity is string && r.activity.size() <= 200))
        && (!('startTimeLocal' in r) || r.startTimeLocal == null
          || (r.startTimeLocal is string && r.startTimeLocal.size() > 0 && r.startTimeLocal.size() <= 5))
        && (!('endTimeLocal' in r) || r.endTimeLocal == null
          || (r.endTimeLocal is string && r.endTimeLocal.size() > 0 && r.endTimeLocal.size() <= 5))
        && (!('tags' in r) || r.tags == null || (r.tags is string && r.tags.size() <= 500))
        && (!('projectId' in r) || r.projectId == null
          || (r.projectId is string && r.projectId.size() > 0 && r.projectId.size() <= 120));
    }

    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string
        && request.resource.data.createdAt == request.time;
      allow update: if isTeamAdmin(teamId);
      allow delete: if false;

      match /members/{userId} {
        allow read: if isTeamMember(teamId)
          || (isSignedIn() && request.auth.uid == userId);
        allow create: if isSignedIn() && request.auth.uid == userId
          && request.resource.data.role is string
          && request.resource.data.displayName is string
          && request.resource.data.email is string
          && request.resource.data.joinedAt == request.time
          && (
            (request.resource.data.role == 'admin'
              && getAfter(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == request.auth.uid)
            || (request.resource.data.role == 'member'
              && get(/databases/$(database)/documents/teams/$(teamId)).data.inviteCode == request.resource.data.inviteCode)
          );
        allow update: if isSignedIn() && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.joinedAt == resource.data.joinedAt
          && request.resource.data.email == resource.data.email
          && (!('inviteCode' in resource.data) || request.resource.data.inviteCode == resource.data.inviteCode);
        allow update: if isTeamAdmin(teamId)
          && request.auth.uid != userId
          && request.resource.data.email == resource.data.email
          && request.resource.data.joinedAt == resource.data.joinedAt
          && request.resource.data.role in ['admin', 'manager', 'member', 'auditor']
          && request.resource.data.displayName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'displayName', 'expectedStartHour', 'expectedStartMinute', 'timezone']);
        allow delete: if isTeamAdmin(teamId) && request.auth.uid != userId;
      }

      match /days/{dateId}/entries/{entryUserId} {
        allow read: if isTeamLeadershipOrAuditor(teamId)
          || (isTeamMember(teamId) && request.auth.uid == entryUserId);
        allow create: if isTeamMember(teamId)
          && request.auth.uid == entryUserId
          && dateId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
        allow update: if dateId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && (
            (isTeamMember(teamId) && request.auth.uid == entryUserId)
            || isTeamAdminOrManager(teamId)
          );
        allow delete: if false;
      }

      match /timeOff/{docId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdminOrManager(teamId);
      }

      match /auditLogs/{logId} {
        allow read: if isTeamLeadershipOrAuditor(teamId);
        allow create: if isTeamAdminOrManager(teamId)
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.action is string;
        allow update, delete: if false;
      }

      match /timesheetLines/{lineId} {
        allow read: if isTeamMember(teamId)
          && (
            resource.data.userId == request.auth.uid
            || isTeamLeadershipOrAuditor(teamId)
          );
        allow create: if isTeamMember(teamId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.dateId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && request.resource.data.project is string
          && request.resource.data.project.size() > 0
          && request.resource.data.project.size() <= 200
          && request.resource.data.client is string
          && request.resource.data.client.size() > 0
          && request.resource.data.client.size() <= 200
          && request.resource.data.task is string
          && request.resource.data.task.size() > 0
          && request.resource.data.task.size() <= 200
          && request.resource.data.hours is number
          && request.resource.data.hours > 0
          && request.resource.data.hours <= 24
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
          && (
            !('notes' in request.resource.data)
            || request.resource.data.notes == null
            || (
              request.resource.data.notes is string
              && request.resource.data.notes.size() <= 2000
            )
          )
          && timesheetOptionalFields(request.resource.data);
        allow update: if isTeamMember(teamId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.dateId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.project is string
          && request.resource.data.project.size() > 0
          && request.resource.data.project.size() <= 200
          && request.resource.data.client is string
          && request.resource.data.client.size() > 0
          && request.resource.data.client.size() <= 200
          && request.resource.data.task is string
          && request.resource.data.task.size() > 0
          && request.resource.data.task.size() <= 200
          && request.resource.data.hours is number
          && request.resource.data.hours > 0
          && request.resource.data.hours <= 24
          && request.resource.data.updatedAt is timestamp
          && (
            !('notes' in request.resource.data)
            || request.resource.data.notes == null
            || (
              request.resource.data.notes is string
              && request.resource.data.notes.size() <= 2000
            )
          )
          && timesheetOptionalFields(request.resource.data);
        allow delete: if isTeamMember(teamId) && resource.data.userId == request.auth.uid;
      }

      match /projects/{projectId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamAdmin(teamId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 200
          && request.resource.data.client is string
          && request.resource.data.client.size() <= 200
          && request.resource.data.archived is bool
          && request.resource.data.createdAt == request.time;
        allow update: if isTeamAdmin(teamId)
          && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isTeamAdmin(teamId);
      }

      match /approvalRequests/{reqId} {
        allow read: if isTeamMember(teamId)
          && (
            isTeamLeadershipOrAuditor(teamId)
            || resource.data.requesterUid == request.auth.uid
          );
        allow create: if isTeamMember(teamId)
          && request.resource.data.kind == 'pto'
          && request.resource.data.status == 'pending'
          && request.resource.data.requesterUid == request.auth.uid
          && request.resource.data.dateId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && (request.resource.data.label == null
            || (request.resource.data.label is string && request.resource.data.label.size() <= 200))
          && (request.resource.data.note == null
            || (request.resource.data.note is string && request.resource.data.note.size() <= 2000))
          && request.resource.data.createdAt == request.time;
        allow update: if isTeamAdminOrManager(teamId)
          && resource.data.status == 'pending'
          && resource.data.kind == 'pto'
          && request.resource.data.kind == resource.data.kind
          && request.resource.data.requesterUid == resource.data.requesterUid
          && request.resource.data.dateId == resource.data.dateId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.label == resource.data.label
          && request.resource.data.note == resource.data.note
          && request.resource.data.status in ['approved', 'rejected']
          && request.resource.data.reviewedByUid == request.auth.uid
          && request.resource.data.reviewedAt == request.time;
        allow delete: if false;
      }
    }
  }
}
